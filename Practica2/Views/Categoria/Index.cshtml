@using Practica2.BLL.DTO
@model List<CategoriaDTO>

@{
    ViewData["Title"] = "Mantenimiento de Categorías";
}

<h1>Lista de Categorías</h1>

<button type="button"
        class="btn btn-success"
        data-bs-toggle="modal"
        data-bs-target="#modalCrearCategoria">
    Crear Categoría
</button>

<table id="tblCategoria"
       class="table table-striped"
       style="width:100%">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody></tbody>

</table>

@await Html.PartialAsync("_Editar")
@await Html.PartialAsync("_Crear")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/categoria.js" asp-append-version="true"></script>
}