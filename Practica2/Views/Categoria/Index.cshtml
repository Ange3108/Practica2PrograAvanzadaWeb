@using Practica2.BLL.DTO
@model List<CategoriaDTO>

@{
    ViewData["Title"] = "Categorías";
}

<div class="page-card">

    <div class="page-header">

        <div>
            <h1>Categorías</h1>
            <p>Administra las categorías de los productos médicos.</p>
        </div>

        <button type="button"
                class="btn btn-main"
                data-bs-toggle="modal"
                data-bs-target="#modalCrearCategoria">
            <i class="bi bi-plus-circle"></i>
            Nueva Categoría
        </button>

    </div>

    <table id="tblCategoria"
           class="table custom-table align-middle"
           style="width:100%">

        <thead>
            <tr>
                <th width="10%">ID</th>
                <th width="30%">Nombre</th>
                <th width="40%">Descripción</th>
                <th width="20%" class="text-center">Acciones</th>
            </tr>
        </thead>

        <tbody></tbody>

    </table>

</div>

@await Html.PartialAsync("_Editar")
@await Html.PartialAsync("_Crear")

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/categoria.js" asp-append-version="true"></script>

}