@model Practica2.BLL.DTO.ProductoDTO

<div class="modal fade"
     id="modalCrearProducto"
     tabindex="-1"
     aria-labelledby="labelModalCrearProducto"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">

            <div class="modal-header modal-header-custom">
                <div>
                    <h5 class="modal-title" id="labelModalCrearProducto">
                        Nuevo Producto
                    </h5>
                    <small>Registra un producto médico en el inventario.</small>
                </div>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <form id="formCrearProducto"
                      asp-action="CreateProducto"
                      asp-controller="Producto"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold">
                            Nombre
                        </label>

                        <input asp-for="Nombre"
                               class="form-control input-custom"
                               placeholder="Ej: Guantes médicos" />

                        <span asp-validation-for="Nombre"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Precio" class="form-label fw-bold">
                            Precio
                        </label>

                        <input asp-for="Precio"
                               type="number"
                               step="0.01"
                               class="form-control input-custom"
                               placeholder="Ej: 2500" />

                        <span asp-validation-for="Precio"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Stock" class="form-label fw-bold">
                            Stock
                        </label>

                        <input asp-for="Stock"
                               type="number"
                               class="form-control input-custom"
                               placeholder="Ej: 50" />

                        <span asp-validation-for="Stock"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IdCategoria" class="form-label fw-bold">
                            Categoría
                        </label>

                        <select asp-for="IdCategoria"
                                class="form-select input-custom">
                            <option value="">-- Seleccione una categoría --</option>

                            @if (ViewBag.Categorias != null)
                            {
                                foreach (var categoria in ViewBag.Categorias)
                                {
                                    <option value="@categoria.IdCategoria">
                                        @categoria.Nombre
                                    </option>
                                }
                            }
                        </select>

                        <span asp-validation-for="IdCategoria"
                              class="text-danger small"></span>
                    </div>

                </form>

            </div>

            <div class="modal-footer modal-footer-custom">

                <button type="button"
                        class="btn btn-cancel"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button"
                        class="btn btn-save"
                        id="btnGuardarProducto">
                    Guardar
                </button>

            </div>

        </div>
    </div>

</div>