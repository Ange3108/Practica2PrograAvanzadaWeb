@model Practica2.BLL.DTO.ProductoDTO

<div class="modal fade"
     id="modalEditarProducto"
     tabindex="-1"
     aria-labelledby="labelModalEditarProducto"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">

            <div class="modal-header modal-header-custom">

                <div>
                    <h5 class="modal-title"
                        id="labelModalEditarProducto">
                        Editar Producto
                    </h5>
                    <small>Actualice la información del producto.</small>
                </div>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <form id="formEditarProducto"
                      asp-action="UpdateProducto"
                      asp-controller="Producto"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input asp-for="IdProducto" type="hidden" />

                    <div class="mb-3">

                        <label asp-for="Nombre"
                               class="form-label fw-bold">
                            Nombre
                        </label>

                        <input asp-for="Nombre"
                               class="form-control input-custom"
                               placeholder="Ingrese el nombre del producto" />

                        <span asp-validation-for="Nombre"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Precio"
                               class="form-label fw-bold">
                            Precio
                        </label>

                        <input asp-for="Precio"
                               type="number"
                               step="0.01"
                               class="form-control input-custom"
                               placeholder="0.00" />

                        <span asp-validation-for="Precio"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Stock"
                               class="form-label fw-bold">
                            Stock
                        </label>

                        <input asp-for="Stock"
                               type="number"
                               class="form-control input-custom"
                               placeholder="Cantidad disponible" />

                        <span asp-validation-for="Stock"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="IdCategoria"
                               class="form-label fw-bold">
                            Categoría
                        </label>

                        <select asp-for="IdCategoria"
                                class="form-select input-custom">

                            <option value="">-- Seleccione una categoría --</option>

                            @if (ViewBag.Categorias != null)
                            {
                                foreach (var categoria in ViewBag.Categorias)
                                {
                                    <option value="@categoria.IdCategoria">
                                        @categoria.Nombre
                                    </option>
                                }
                            }

                        </select>

                        <span asp-validation-for="IdCategoria"
                              class="text-danger small"></span>

                    </div>

                </form>

            </div>

            <div class="modal-footer modal-footer-custom">

                <button type="button"
                        class="btn btn-cancel"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button"
                        class="btn btn-save"
                        id="btnEditarProducto">
                    Guardar cambios
                </button>

            </div>

        </div>
    </div>

</div>